{
  "manifest_version": 2,
  "name": "BrowserSync — Drive Backup",
  "version": "1.0.0",
  "description": "Sync bookmarks, history, passwords export, and extensions list to Google Drive.",
  "permissions": [
    "bookmarks",
    "history",
    "storage",
    "identity",
    "downloads",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "browsersync@yourdomain.com",
      "strict_min_version": "91.0"
    }
  },
  "icons": {
    "48": "icons/icon48.png"
  }
}
